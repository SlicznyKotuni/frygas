#:kivy 2.0.0

<Kotun>:
    Image:
        fit_mode: 'fill'  # or 'contain', 'cover', etc.
    # keep_ratio is replaced by fit_mode behavior
        canvas.before:
            Color:
                rgba: 0, 0, 0, 0  # Przezroczyste tło
            Rectangle:
                pos: self.pos
                size: self.size